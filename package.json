    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.3",
    "file-type": "^22.0.1",
