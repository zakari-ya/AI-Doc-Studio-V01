# Required: secret used by the Vercel serverless function.
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# Required in production: canonical application URL.
APP_BASE_URL="http://localhost:3000"

# Optional but recommended: explicit comma-separated origin allowlist.
ALLOWED_ORIGINS="http://localhost:3000"

# Optional: provider attribution header sent to OpenRouter.
OPENROUTER_HTTP_REFERER="http://localhost:3000"

# Optional: enable durable rate limiting when Vercel KV is attached.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
