# Supabase browser auth, private storage, and server access
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
VITE_SUPABASE_STORAGE_BUCKET="documents-temp"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="documents-temp"
SUPABASE_DATABASE_URL=""
SUPABASE_DATABASE_SSL="true"

# OpenRouter reconstruction
OPENROUTER_API_KEY=""

# Required in production: canonical application URL.
APP_BASE_URL="http://localhost:3000"

# Optional but recommended: explicit comma-separated origin allowlist.
ALLOWED_ORIGINS="http://localhost:3000"

# Optional: provider attribution header sent to OpenRouter.
OPENROUTER_HTTP_REFERER="http://localhost:3000"

# Vercel Cron cleanup endpoint secret.
CRON_SECRET=""
